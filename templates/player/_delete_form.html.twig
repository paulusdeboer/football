<form method="post" action="{{ path('app_player_delete', {'id': player.id}) }}" onsubmit="return confirm({% trans %}'Are you sure you want to delete this item?'{% endtrans %});">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ player.id) }}">
    <button class="btn">{% trans %}Delete{% endtrans %}</button>
</form>
